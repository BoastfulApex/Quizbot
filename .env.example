# Telegram bot
BOT_TOKEN=123456:ABC-your-telegram-bot-token
ADMIN_IDS=111111111,222222222

# Anthropic Claude API (savol generatsiyasi uchun)
ANTHROPIC_API_KEY=sk-ant-your-api-key

# PostgreSQL (docker-compose "db" xizmati bilan mos: host konteynerdan ishga tushirilsa
# POSTGRES_HOST=localhost, docker-compose ichidan bo'lsa POSTGRES_HOST=db)
POSTGRES_DB=quizbot
POSTGRES_USER=quizbot
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
